<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_LoginAutenticacao" targetNamespace="https://chatbotcrm.local/bpmn">
  <bpmn:process id="Process_LoginAutenticacao" name="Login e Autenticação" isExecutable="false">
    <bpmn:documentation>Fluxo de autenticação do ChatBotCRM com perfis de acesso: super admin, admin/gerente e atendente. Preparado para multiusuário, permissões, empresa Sol Restaurante e futura expansão SaaS multiempresa.</bpmn:documentation>
    <bpmn:startEvent id="Start_AcessaCRM" name="Usuário acessa o CRM">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_DadosLogin" name="Informar e-mail e senha">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ValidarCredenciais" name="Validar credenciais">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_CredenciaisValidas" name="Credenciais válidas?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ErroLogin" name="Exibir erro e permitir nova tentativa">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_UsuarioAtivo" name="Usuário ativo?">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_BloquearAcesso" name="Bloquear acesso e orientar contato com administrador">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_CarregarEmpresa" name="Carregar empresa: Sol Restaurante">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CarregarPermissoes" name="Carregar perfil e permissões">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Perfil" name="Perfil do usuário">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_SuperAdmin" name="Super admin: painel completo e configurações globais">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_AdminGerente" name="Admin/gerente: operação, usuários e relatórios">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Atendente" name="Atendente: conversas, pedidos e impressão">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_Logado" name="Sessão iniciada com segurança">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:incoming>Flow_16</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_AcessaCRM" targetRef="Task_DadosLogin" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_DadosLogin" targetRef="Task_ValidarCredenciais" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_ValidarCredenciais" targetRef="Gateway_CredenciaisValidas" />
    <bpmn:sequenceFlow id="Flow_4" name="Sim" sourceRef="Gateway_CredenciaisValidas" targetRef="Gateway_UsuarioAtivo" />
    <bpmn:sequenceFlow id="Flow_5" name="Não" sourceRef="Gateway_CredenciaisValidas" targetRef="Task_ErroLogin" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_ErroLogin" targetRef="Task_DadosLogin" />
    <bpmn:sequenceFlow id="Flow_7" name="Sim" sourceRef="Gateway_UsuarioAtivo" targetRef="Task_CarregarEmpresa" />
    <bpmn:sequenceFlow id="Flow_8" name="Não" sourceRef="Gateway_UsuarioAtivo" targetRef="Task_BloquearAcesso" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_CarregarEmpresa" targetRef="Task_CarregarPermissoes" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_CarregarPermissoes" targetRef="Gateway_Perfil" />
    <bpmn:sequenceFlow id="Flow_11" name="Super admin" sourceRef="Gateway_Perfil" targetRef="Task_SuperAdmin" />
    <bpmn:sequenceFlow id="Flow_12" name="Admin/Gerente" sourceRef="Gateway_Perfil" targetRef="Task_AdminGerente" />
    <bpmn:sequenceFlow id="Flow_13" name="Atendente" sourceRef="Gateway_Perfil" targetRef="Task_Atendente" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_SuperAdmin" targetRef="End_Logado" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_AdminGerente" targetRef="End_Logado" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_Atendente" targetRef="End_Logado" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Process_LoginAutenticacao">
    <bpmndi:BPMNPlane id="BPMNPlane_Process_LoginAutenticacao" bpmnElement="Process_LoginAutenticacao">
      <bpmndi:BPMNShape id="Start_AcessaCRM_di" bpmnElement="Start_AcessaCRM">
        <dc:Bounds x="80" y="230" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DadosLogin_di" bpmnElement="Task_DadosLogin">
        <dc:Bounds x="160" y="205" width="190" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ValidarCredenciais_di" bpmnElement="Task_ValidarCredenciais">
        <dc:Bounds x="400" y="205" width="190" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_CredenciaisValidas_di" bpmnElement="Gateway_CredenciaisValidas">
        <dc:Bounds x="650" y="223" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ErroLogin_di" bpmnElement="Task_ErroLogin">
        <dc:Bounds x="755" y="345" width="190" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_UsuarioAtivo_di" bpmnElement="Gateway_UsuarioAtivo">
        <dc:Bounds x="755" y="223" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_BloquearAcesso_di" bpmnElement="Task_BloquearAcesso">
        <dc:Bounds x="875" y="345" width="190" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CarregarEmpresa_di" bpmnElement="Task_CarregarEmpresa">
        <dc:Bounds x="875" y="205" width="190" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CarregarPermissoes_di" bpmnElement="Task_CarregarPermissoes">
        <dc:Bounds x="1115" y="205" width="190" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Perfil_di" bpmnElement="Gateway_Perfil">
        <dc:Bounds x="1365" y="223" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SuperAdmin_di" bpmnElement="Task_SuperAdmin">
        <dc:Bounds x="1475" y="70" width="190" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdminGerente_di" bpmnElement="Task_AdminGerente">
        <dc:Bounds x="1475" y="205" width="190" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Atendente_di" bpmnElement="Task_Atendente">
        <dc:Bounds x="1475" y="340" width="190" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Logado_di" bpmnElement="End_Logado">
        <dc:Bounds x="1725" y="230" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="116" y="248" />
        <di:waypoint x="160" y="248" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="350" y="248" />
        <di:waypoint x="400" y="248" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="590" y="248" />
        <di:waypoint x="650" y="248" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="700" y="248" />
        <di:waypoint x="755" y="248" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
