        <di:waypoint x="1860" y="338" />
        <di:waypoint x="1595" y="338" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1540" y="248" />
        <di:waypoint x="1568" y="248" />
        <di:waypoint x="1568" y="338" />
        <di:waypoint x="1595" y="338" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_16_di" bpmnElement="Flow_16">
        <di:waypoint x="1785" y="338" />
